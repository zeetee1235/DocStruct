{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DocStruct GUI",
  "version": "0.1.0",
  "identifier": "com.docstruct.gui",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DocStruct GUI",
        "width": 1024,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
